# Frontend Environment Configuration
# Copy this to .env and fill in your values

# Starknet Network (sepolia or mainnet)
REACT_APP_STARKNET_NETWORK=sepolia

# RPC URL for Starknet
REACT_APP_RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_7

# Deployed GameScores contract address
# You'll get this after deploying the contract
REACT_APP_GAME_SCORES_CONTRACT=0xYOUR_DEPLOYED_CONTRACT_ADDRESS
