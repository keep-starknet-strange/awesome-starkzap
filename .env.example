# Starknet Deployment Configuration
# Copy this to .env and fill in your values

# Starknet Sepolia testnet RPC URL
STARKNET_RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_7

# Your deployer wallet private key (NEVER COMMIT THIS!)
# Get Sepolia STRK from: https://starknet-faucet.vercel.app/
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Your deployer wallet address
DEPLOYER_ADDRESS=0xYOUR_WALLET_ADDRESS

# After deployment, add the contract address here:
# GAME_SCORES_CONTRACT=0xYOUR_DEPLOYED_CONTRACT_ADDRESS
